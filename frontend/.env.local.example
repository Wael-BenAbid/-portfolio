# ===========================================
# Frontend Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# ⚠️ NEVER commit .env.local to version control!
# ⚠️ This file is tracked by git for documentation purposes only

# ===========================================
# API Configuration
# ===========================================

# Backend API URL (for Vite proxy)
# Use /api for development (proxied through Vite)
# Use full URL for production: https://yourdomain.com/api
VITE_API_URL=http://localhost:8000/api

# ===========================================
# External API Keys
# ===========================================

# Google Gemini API Key (for AI features)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================

# Google Analytics (optional)
# VITE_GA_MEASUREMENT_ID=

# Sentry DSN (optional, for error tracking)
# VITE_SENTRY_DSN=

# ===========================================
# Optional: Feature Flags
# ===========================================

# Enable/disable features
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_MONITORING=false