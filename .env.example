# ===========================================
# Portfolio Project Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to version control!
# ⚠️ This file is tracked by git for documentation purposes only

# ===========================================
# Django Settings - SECURITY CRITICAL
# ===========================================

# Generate a secure secret key:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production

# Debug mode (ALWAYS 'false' in production)
# ⚠️ Setting this to 'true' exposes your code, environment variables, and errors
DJANGO_DEBUG=false

# Allowed hosts (comma-separated, required in production)
# Example: portfolio.com,www.portfolio.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# ===========================================
# Database Settings - PostgreSQL
# ===========================================

DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=your-secure-database-password-change-this
DB_HOST=localhost
DB_PORT=5433

# ===========================================
# Redis Cache Settings
# ===========================================

# Leave empty for local development without Redis
# Set to redis://redis:6379/1 for Docker/production
REDIS_URL=

# ===========================================
# SECURITY Settings - CORS & CSRF
# ===========================================

# CSRF trusted origins (comma-separated, HTTPS in production)
# Only specify domains where your frontend is hosted
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# CORS allowed origins (comma-separated, HTTPS in production)
# Only specify domains where your frontend is hosted
# Example for production: https://portfolio.com,https://www.portfolio.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# Email Settings (for contact form & notifications)
# ===========================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@portfolio.com

# ===========================================
# Frontend Settings
# ===========================================

# API URL for frontend (used in Vite config)
REACT_APP_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000/api

# ===========================================
# Social Authentication (Optional)
# ===========================================

# Google OAuth2 - Uncomment and fill if using Google login
# Get from: https://console.cloud.google.com
# GOOGLE_OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH2_CLIENT_SECRET=your-client-secret

# Facebook OAuth - Uncomment and fill if using Facebook login
# Get from: https://developers.facebook.com
# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret

# ===========================================
# Logging & Environment
# ===========================================

# Django log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# Environment type (development, staging, production)
ENVIRONMENT=development

# ===========================================
# Monitoring (Prometheus & Grafana)
# ===========================================

# Grafana admin credentials (required for monitoring stack)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password-change-this

# Initial admin user for Django (required for first-time setup)
# Set these before running migrations to create the initial admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=your-secure-admin-password-change-this
